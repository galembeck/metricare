{
  "name": "@metricare/api",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "pnpm env:load tsx watch src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "db:generate": "pnpm env:load prisma generate",
    "db:migrate": "pnpm env:load prisma migrate dev",
    "db:seed": "pnpm env:load prisma db seed",
    "db:studio": "pnpm env:load prisma studio",
    "env:load": "dotenv -e ../../.env --",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/swagger": "^9.7.0",
    "@prisma/client": "^7.8.0",
    "@metricare/env": "workspace:*",
    "@scalar/fastify-api-reference": "^1.57.2",
    "bcryptjs": "^3.0.3",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@metricare/eslint-config": "workspace:*",
    "@metricare/prettier-config": "workspace:*",
    "@metricare/typescript-config": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.7",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7"
  },
  "prettier": "@metricare/prettier-config",
  "eslintConfig": {
    "extends": [
      "@metricare/eslint-config/node"
    ]
  }
}
