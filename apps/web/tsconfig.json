  "extends": "@metricare/typescript-config/vite.json",
  "include": ["src"],
  "compilerOptions": {
    "strictNullChecks": true,
    "ignoreDeprecations": "6.0",
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "exclude": ["./src/route-tree-gen.ts", "./src/http/gen"]
}
